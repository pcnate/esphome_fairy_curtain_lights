wifi_ssid: "your-ssid"
wifi_password: "your-wifi-password"

# ESPHome Home Assistant API encryption key (base64-encoded 32 bytes).
# Generate with: openssl rand -base64 32
api_encryption_key: "REPLACE_ME_WITH_BASE64_32_BYTES"

# OTA update password (any string).
ota_password: "REPLACE_ME_WITH_OTA_PASSWORD"

# Fallback AP password shown if Wi-Fi fails (8+ chars).
ap_fallback_password: "REPLACE_ME_WITH_AP_PASSWORD"
