esphome:
  name: curtain-lights-dev
  friendly_name: curtain-lights-dev

  on_boot:
    priority: -10
    then:
      - wait_until:
          api.connected:
      - logger.log: API is connected!
      - rtttl.play: "success:d=24,o=5,b=100:c,g,b"
      - light.turn_on:
          id: board_led
          brightness: 100%
          red: 0%
          green: 0%
          blue: 100%
          flash_length: 500ms

external_components:
  - source:
      type: local
      path: ../components
    components: [ fairy_curtain_lights ]

esp32:
  board: esp32-s3-devkitc-1
  framework:
    type: arduino

logger:

api:
  encryption:
    key: !secret api_encryption_key

ota:
  - platform: esphome
    password: !secret ota_password

wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password

  ap:
    ssid: "Curtain-Lights-Dev"
    password: !secret ap_fallback_password

captive_portal:

time:
  - platform: sntp
    id: sntp_time
    servers:
      - ntp.unr34l.net

fairy_curtain_lights:
  gpio_a: 1
  gpio_b: 2
  frequency: 1000
  id_a: pwm_out_a
  id_b: pwm_out_b

output:
  - platform: ledc
    pin: GPIO14
    id: buzzer

rtttl:
  output: buzzer
  id: rtttl_buzzer
  gain: 30%

light:
  - platform: neopixelbus
    type: RGB
    pin: GPIO21
    num_leds: 1
    variant: 800KBPS
    name: "Board RGB LED"
    id: board_led
    restore_mode: ALWAYS_OFF
